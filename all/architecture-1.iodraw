<svg width="100%" viewBox="0 0 680 780" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </marker>
  </defs>

  <!-- 背景 -->
  <rect width="680" height="780" fill="#ffffff"/>

  <!-- 第一层：客户端 -->
  <rect x="240" y="16" width="200" height="44" rx="8" fill="#EEEDFE" stroke="#534AB7" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="14" font-weight="500" x="340" y="34" text-anchor="middle" dominant-baseline="central" fill="#3C3489">外部智能平台</text>
  <text font-family="sans-serif" font-size="12" x="340" y="50" text-anchor="middle" dominant-baseline="central" fill="#534AB7">通过 VIP 接入算力</text>

  <!-- 箭头 客户端 → VIP -->
  <line x1="340" y1="60" x2="340" y2="80" stroke="#888780" stroke-width="1.5" marker-end="url(#arrow)"/>

  <!-- 第二层：Keepalived VIP -->
  <rect x="190" y="82" width="300" height="44" rx="8" fill="#FAEEDA" stroke="#BA7517" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="14" font-weight="500" x="340" y="100" text-anchor="middle" dominant-baseline="central" fill="#633806">Keepalived VIP · 统一对外入口</text>
  <text font-family="sans-serif" font-size="12" x="340" y="116" text-anchor="middle" dominant-baseline="central" fill="#854F0B">VRRP 故障自动漂移</text>

  <!-- 箭头 VIP → HAProxy -->
  <line x1="340" y1="126" x2="340" y2="146" stroke="#888780" stroke-width="1.5" marker-end="url(#arrow)"/>

  <!-- 第三层：HAProxy -->
  <rect x="190" y="148" width="300" height="44" rx="8" fill="#E1F5EE" stroke="#0F6E56" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="14" font-weight="500" x="340" y="166" text-anchor="middle" dominant-baseline="central" fill="#085041">HAProxy · 负载均衡</text>
  <text font-family="sans-serif" font-size="12" x="340" y="182" text-anchor="middle" dominant-baseline="central" fill="#0F6E56">轮询分发到三台 LiteLLM</text>

  <!-- 箭头 HAProxy → 三台LiteLLM -->
  <line x1="340" y1="192" x2="340" y2="206" stroke="#888780" stroke-width="0.5"/>
  <line x1="116" y1="206" x2="564" y2="206" stroke="#888780" stroke-width="0.5"/>
  <line x1="116" y1="206" x2="116" y2="222" stroke="#888780" stroke-width="1.5" marker-end="url(#arrow)"/>
  <line x1="340" y1="206" x2="340" y2="222" stroke="#888780" stroke-width="1.5" marker-end="url(#arrow)"/>
  <line x1="564" y1="206" x2="564" y2="222" stroke="#888780" stroke-width="1.5" marker-end="url(#arrow)"/>

  <!-- 第四层：三台 LiteLLM -->
  <!-- 机器1 -->
  <rect x="20" y="224" width="192" height="110" rx="8" fill="#E6F1FB" stroke="#185FA5" stroke-width="0.5"/>
  <rect x="28" y="232" width="176" height="26" rx="4" fill="#185FA5"/>
  <text font-family="sans-serif" font-size="14" font-weight="500" x="116" y="245" text-anchor="middle" dominant-baseline="central" fill="#ffffff">10.0.0.5 泰山</text>
  <text font-family="sans-serif" font-size="12" x="116" y="268" text-anchor="middle" fill="#0C447C">LiteLLM</text>
  <text font-family="sans-serif" font-size="12" x="116" y="284" text-anchor="middle" fill="#0C447C">Keepalived MASTER</text>
  <text font-family="sans-serif" font-size="12" x="116" y="300" text-anchor="middle" fill="#0C447C">HAProxy</text>
  <text font-family="sans-serif" font-size="12" x="116" y="316" text-anchor="middle" fill="#0C447C">Elasticsearch</text>

  <!-- 机器2 -->
  <rect x="244" y="224" width="192" height="110" rx="8" fill="#E6F1FB" stroke="#185FA5" stroke-width="0.5"/>
  <rect x="252" y="232" width="176" height="26" rx="4" fill="#185FA5"/>
  <text font-family="sans-serif" font-size="14" font-weight="500" x="340" y="245" text-anchor="middle" dominant-baseline="central" fill="#ffffff">10.0.0.6 泰山</text>
  <text font-family="sans-serif" font-size="12" x="340" y="268" text-anchor="middle" fill="#0C447C">LiteLLM</text>
  <text font-family="sans-serif" font-size="12" x="340" y="284" text-anchor="middle" fill="#0C447C">Keepalived BACKUP1</text>
  <text font-family="sans-serif" font-size="12" x="340" y="300" text-anchor="middle" fill="#0C447C">HAProxy</text>
  <text font-family="sans-serif" font-size="12" x="340" y="316" text-anchor="middle" fill="#0C447C">Elasticsearch</text>

  <!-- 机器3 -->
  <rect x="468" y="224" width="192" height="110" rx="8" fill="#E6F1FB" stroke="#185FA5" stroke-width="0.5"/>
  <rect x="476" y="232" width="176" height="26" rx="4" fill="#185FA5"/>
  <text font-family="sans-serif" font-size="14" font-weight="500" x="564" y="245" text-anchor="middle" dominant-baseline="central" fill="#ffffff">10.0.0.7 泰山</text>
  <text font-family="sans-serif" font-size="12" x="564" y="268" text-anchor="middle" fill="#0C447C">LiteLLM</text>
  <text font-family="sans-serif" font-size="12" x="564" y="284" text-anchor="middle" fill="#0C447C">Keepalived BACKUP2</text>
  <text font-family="sans-serif" font-size="12" x="564" y="300" text-anchor="middle" fill="#0C447C">HAProxy</text>
  <text font-family="sans-serif" font-size="12" x="564" y="316" text-anchor="middle" fill="#0C447C">Elasticsearch</text>

  <!-- ES集群连线 -->
  <line x1="212" y1="334" x2="244" y2="334" stroke="#888780" stroke-width="0.5" stroke-dasharray="3 3"/>
  <line x1="436" y1="334" x2="468" y2="334" stroke="#888780" stroke-width="0.5" stroke-dasharray="3 3"/>
  <text font-family="sans-serif" font-size="12" x="340" y="352" text-anchor="middle" fill="#5F5E5A">ES 集群 · 三节点 · 存储 MCP 图片 / 知识库文档</text>

  <!-- 箭头 三台LiteLLM → 路由 -->
  <line x1="116" y1="360" x2="116" y2="374" stroke="#888780" stroke-width="0.5"/>
  <line x1="340" y1="360" x2="340" y2="374" stroke="#888780" stroke-width="0.5"/>
  <line x1="564" y1="360" x2="564" y2="374" stroke="#888780" stroke-width="0.5"/>
  <line x1="116" y1="374" x2="564" y2="374" stroke="#888780" stroke-width="0.5"/>
  <line x1="340" y1="374" x2="340" y2="388" stroke="#888780" stroke-width="1.5" marker-end="url(#arrow)"/>

  <!-- 路由说明 -->
  <rect x="190" y="390" width="300" height="34" rx="8" fill="#F1EFE8" stroke="#5F5E5A" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="14" font-weight="500" x="340" y="407" text-anchor="middle" dominant-baseline="central" fill="#2C2C2A">LiteLLM 按 model 路由到后端</text>

  <!-- 箭头 路由 → GPU -->
  <line x1="340" y1="424" x2="340" y2="436" stroke="#888780" stroke-width="0.5"/>
  <line x1="94" y1="436" x2="577" y2="436" stroke="#888780" stroke-width="0.5"/>
  <line x1="94"  y1="436" x2="94"  y2="450" stroke="#888780" stroke-width="1.5" marker-end="url(#arrow)"/>
  <line x1="252" y1="436" x2="252" y2="450" stroke="#888780" stroke-width="1.5" marker-end="url(#arrow)"/>
  <line x1="410" y1="436" x2="410" y2="450" stroke="#888780" stroke-width="1.5" marker-end="url(#arrow)"/>
  <line x1="577" y1="436" x2="577" y2="450" stroke="#888780" stroke-width="1.5" marker-end="url(#arrow)"/>

  <!-- GPU S1 -->
  <rect x="20" y="452" width="148" height="300" rx="8" fill="#FAECE7" stroke="#993C1D" stroke-width="0.5"/>
  <rect x="28" y="460" width="132" height="26" rx="4" fill="#993C1D"/>
  <text font-family="sans-serif" font-size="14" font-weight="500" x="94" y="473" text-anchor="middle" dominant-baseline="central" fill="#ffffff">10.0.0.1</text>
  <text font-family="sans-serif" font-size="12" x="94" y="502" text-anchor="middle" fill="#712B13">P800 × 8</text>
  <line x1="30" y1="512" x2="158" y2="512" stroke="#F5C4B3" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="12" x="94" y="528" text-anchor="middle" fill="#712B13">vLLM</text>
  <line x1="30" y1="540" x2="158" y2="540" stroke="#F5C4B3" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="13" font-weight="500" x="94" y="558" text-anchor="middle" fill="#712B13">DeepSeek-72B</text>

  <!-- GPU S2 -->
  <rect x="178" y="452" width="148" height="300" rx="8" fill="#FAECE7" stroke="#993C1D" stroke-width="0.5"/>
  <rect x="186" y="460" width="132" height="26" rx="4" fill="#993C1D"/>
  <text font-family="sans-serif" font-size="14" font-weight="500" x="252" y="473" text-anchor="middle" dominant-baseline="central" fill="#ffffff">10.0.0.2</text>
  <text font-family="sans-serif" font-size="12" x="252" y="502" text-anchor="middle" fill="#712B13">P800 × 8</text>
  <line x1="188" y1="512" x2="316" y2="512" stroke="#F5C4B3" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="12" x="252" y="528" text-anchor="middle" fill="#712B13">vLLM</text>
  <line x1="188" y1="540" x2="316" y2="540" stroke="#F5C4B3" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="12" font-weight="500" x="252" y="558" text-anchor="middle" fill="#712B13">Qwen3-VL-30B</text>
  <text font-family="sans-serif" font-size="12" font-weight="500" x="252" y="576" text-anchor="middle" fill="#712B13">Qwen3-Omni-30B</text>
  <text font-family="sans-serif" font-size="12" font-weight="500" x="252" y="594" text-anchor="middle" fill="#712B13">Qwen3-Next</text>

  <!-- GPU S3 -->
  <rect x="336" y="452" width="148" height="300" rx="8" fill="#E1F5EE" stroke="#0F6E56" stroke-width="0.5"/>
  <rect x="344" y="460" width="132" height="26" rx="4" fill="#0F6E56"/>
  <text font-family="sans-serif" font-size="14" font-weight="500" x="410" y="473" text-anchor="middle" dominant-baseline="central" fill="#ffffff">10.0.0.3</text>
  <text font-family="sans-serif" font-size="12" x="410" y="502" text-anchor="middle" fill="#085041">A800 × 1</text>
  <line x1="346" y1="512" x2="474" y2="512" stroke="#9FE1CB" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="12" x="410" y="528" text-anchor="middle" fill="#085041">vLLM</text>
  <line x1="346" y1="540" x2="474" y2="540" stroke="#9FE1CB" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="12" font-weight="500" x="410" y="558" text-anchor="middle" fill="#085041">Qwen3-Coder-30B</text>
  <text font-family="sans-serif" font-size="12" font-weight="500" x="410" y="574" text-anchor="middle" fill="#085041">AWQ</text>
  <line x1="346" y1="588" x2="474" y2="588" stroke="#9FE1CB" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="12" x="410" y="604" text-anchor="middle" fill="#085041">SQLBot · Dify</text>
  <text font-family="sans-serif" font-size="12" x="410" y="620" text-anchor="middle" fill="#085041">SuperSonic</text>
  <text font-family="sans-serif" font-size="11" x="410" y="638" text-anchor="middle" fill="#0F6E56">内网调用 LiteLLM</text>

  <!-- GPU S4 -->
  <rect x="494" y="452" width="166" height="300" rx="8" fill="#E1F5EE" stroke="#0F6E56" stroke-width="0.5"/>
  <rect x="502" y="460" width="150" height="26" rx="4" fill="#0F6E56"/>
  <text font-family="sans-serif" font-size="14" font-weight="500" x="577" y="473" text-anchor="middle" dominant-baseline="central" fill="#ffffff">10.0.0.4</text>
  <text font-family="sans-serif" font-size="12" x="577" y="502" text-anchor="middle" fill="#085041">T4 × 8</text>
  <line x1="504" y1="512" x2="650" y2="512" stroke="#9FE1CB" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="12" x="577" y="528" text-anchor="middle" fill="#085041">Xinference</text>
  <line x1="504" y1="540" x2="650" y2="540" stroke="#9FE1CB" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="12" font-weight="500" x="577" y="558" text-anchor="middle" fill="#085041">bge-large-zh</text>
  <text font-family="sans-serif" font-size="12" font-weight="500" x="577" y="576" text-anchor="middle" fill="#085041">bge-reranker</text>
  <text font-family="sans-serif" font-size="12" font-weight="500" x="577" y="594" text-anchor="middle" fill="#085041">PaddleOCR</text>
  <text font-family="sans-serif" font-size="12" font-weight="500" x="577" y="612" text-anchor="middle" fill="#085041">DocAI-API</text>
  <line x1="504" y1="626" x2="650" y2="626" stroke="#9FE1CB" stroke-width="0.5"/>
  <text font-family="sans-serif" font-size="12" x="577" y="644" text-anchor="middle" fill="#085041">RAGFlow</text>
  <text font-family="sans-serif" font-size="11" x="577" y="660" text-anchor="middle" fill="#0F6E56">内网调用 LiteLLM</text>

  <!-- 内网调用虚线 -->
  <path d="M410 452 L410 440 L200 440 L200 360" fill="none" stroke="#888780" stroke-width="0.5" stroke-dasharray="4 3"/>
  <path d="M577 452 L577 440 L480 440 L480 360" fill="none" stroke="#888780" stroke-width="0.5" stroke-dasharray="4 3"/>

  <!-- 图例 -->
  <rect x="20" y="762" width="10" height="8" rx="2" fill="#993C1D"/>
  <text font-family="sans-serif" font-size="11" x="34" y="770" fill="#5F5E5A">纯算力节点</text>
  <rect x="130" y="762" width="10" height="8" rx="2" fill="#0F6E56"/>
  <text font-family="sans-serif" font-size="11" x="144" y="770" fill="#5F5E5A">算力 + 智能平台（内网调用）</text>
  <rect x="360" y="762" width="10" height="8" rx="2" fill="#185FA5"/>
  <text font-family="sans-serif" font-size="11" x="374" y="770" fill="#5F5E5A">模型网关节点</text>
  <line x1="480" y1="766" x2="500" y2="766" stroke="#888780" stroke-width="0.5" stroke-dasharray="4 3"/>
  <text font-family="sans-serif" font-size="11" x="506" y="770" fill="#5F5E5A">内网调用</text>
</svg>
